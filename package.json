{
  "name": "agents-md-sync",
  "version": "0.3.3",
  "description": "Sync AGENTS.md across many repositories from a central markdown template repo, via pull requests.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/trick77/agents-md-sync.git"
  },
  "bugs": {
    "url": "https://github.com/trick77/agents-md-sync/issues"
  },
  "homepage": "https://github.com/trick77/agents-md-sync#readme",
  "keywords": [
    "agents.md",
    "ai",
    "cli",
    "markdown",
    "template",
    "sync",
    "pull-request"
  ],
  "type": "module",
  "bin": {
    "agents-md-sync": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "npm run check:samples && npm run lint && vitest run",
    "coverage": "vitest run --coverage",
    "dev": "tsx src/index.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "render:samples": "tsx scripts/render-samples.ts",
    "check:samples": "tsx scripts/check-samples.ts",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "simple-git": "^3.36.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.2",
    "tsx": "^4.19.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.4"
  }
}
